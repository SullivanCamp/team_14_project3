<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manager View</title>
  <link rel="stylesheet" href="/css/login.css" />
</head>
<body>
  <main class="login-page">
    <section class="login-card">
      <p class="eyebrow">Manager View</p>
      <h1>Reports Dashboard</h1>
      <p class="subtext">Choose a report to view.</p>

      <div class="role-buttons">
        <a href="/reports/x" class="role-btn manager">X Report</a>
        <a href="/reports/z" class="role-btn manager">Z Report</a>
        <a href="/reports/trends" class="role-btn manager">Order Trends</a>
        <a href="/reports/product-usage" class="role-btn manager">Product Usage</a>
        <a href="/login" class="role-btn customer">Back</a>
      </div>
    </section>
  </main>
</body>
</html>