<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Team 14 Kiosk</title>
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
  <main class="auth-shell">
    <section class="auth-card">
      <div class="brand-pill">Team 14 Kiosk</div>

      <div id="startScreen" class="auth-panel active">
        <h1>Welcome In</h1>
        <p class="subtitle">
          Log in for rewards, make an account real quick, or just skip and order.
        </p>

        <div class="auth-actions">
          <button class="auth-btn primary" id="showLoginBtn" type="button">Log In</button>
          <button class="auth-btn secondary" id="showSignupBtn" type="button">Sign Up</button>
          <button class="auth-btn ghost" id="skipBtn" type="button">Skip for Now</button>
        </div>
      </div>

      <div id="loginScreen" class="auth-panel">
        <button class="back-btn" id="backFromLogin" type="button">← Back</button>
        <h2>Log In</h2>

        <form id="loginForm" class="auth-form">
          <label for="loginIdentifier">Email or Phone</label>
          <input type="text" id="loginIdentifier" placeholder="Enter your email or phone" required>

          <label for="loginPassword">Password</label>
          <input type="password" id="loginPassword" placeholder="Enter your password" required>

          <button class="auth-btn primary" type="submit">Continue to Menu</button>
        </form>
      </div>

      <div id="signupScreen" class="auth-panel">
        <button class="back-btn" id="backFromSignup" type="button">← Back</button>
        <h2>Create Account</h2>

        <form id="signupForm" class="auth-form">
          <label for="signupFirstName">First Name</label>
          <input type="text" id="signupFirstName" placeholder="First name" required>

          <label for="signupLastName">Last Name</label>
          <input type="text" id="signupLastName" placeholder="Last name">

          <label for="signupEmail">Email</label>
          <input type="email" id="signupEmail" placeholder="Enter your email" required>

          <label for="signupPhone">Phone Number</label>
          <input type="text" id="signupPhone" placeholder="Enter your phone number">

          <label for="signupPassword">Password</label>
          <input type="password" id="signupPassword" placeholder="Enter your password" required>

          <button class="auth-btn primary" type="submit">Create Account and Order</button>
        </form>
      </div>

      <p id="authMessage" class="auth-message"></p>
    </section>
  </main>

  <script src="/js/auth.js"></script>
</body>
</html>