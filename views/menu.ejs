<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title data-i18n="pageTitleMenu">Team 14 Menu</title>
  <link rel="stylesheet" href="/css/menu.css">
  <link rel="stylesheet" href="/css/addonpopup.css">
  <link rel="stylesheet" href="/css/chat.css">
  <script src="https://code.responsivevoice.org/responsivevoice.js"></script>
</head>
<body>
  <div class="page-shell">
    <main class="menu-container">
      <header class="menu-header">
        <h1 data-i18n="brandName">Team 14</h1>

        <input
          type="text"
          id="searchInput"
          class="search-bar"
          placeholder="Search drinks..."
          data-i18n-placeholder="searchDrinks"
        />
        <button id="screenReaderToggle" class="screen-reader-btn" data-i18n="screenReader" type="button" data-reader="Screen reader enabled. Use the tab key to navigate the page.">
          Enable Screen Reader
        </button>
        <div class="header-actions">
          <% if (typeof user !== "undefined" && user) { %>
            <a href="/" class="staff-back-btn">← Back to Staff</a>
          <% } %>

          <select id="languageSelect" class="language-select" aria-label="Language selector">
            <option value="en">English</option>
            <option value="es">Español</option>
            <option value="fr">Français</option>
            <option value="zh-CN">中文</option>
          </select>

          <button class="chat-btn" id="chatBtn" data-i18n="askTapi" onclick="openChatWindow()">Ask Tapi!</button>

          <div class="customer-menu-wrapper" id="customerMenuWrapper">

            <button class="customer-chip" id="customerChip" type="button">
              <span id="customerChipName" >Guest</span>
              <span class="customer-chip-arrow">▾</span>
            </button>

            <div class="customer-dropdown" id="customerDropdown">
              <p class="customer-dropdown-title" data-i18n="signedInAs">Signed in as</p>
              <p class="customer-dropdown-name" id="customerDropdownName" data-i18n="guest">Guest</p>
              <button class="customer-dropdown-btn" id="switchAccountBtn" type="button" data-i18n="changeAccount">Change Account</button>
              <button class="customer-dropdown-btn logout" id="logoutBtn" type="button" data-i18n="logOut">Log Out</button>
            </div>
          </div>

          <button class="rewards-btn" type="button" id="rewardsBtn">
            <span data-i18n="rewards">Rewards</span>: <span id="rewardsPoints">0</span> pts
            (<span id="rewardsTier">Standard</span>)
          </button>

          <a href="/checkout" class="cart-link">
            <button class="cart-btn" id="cartBtn" type="button">
              <span data-i18n="viewCart">View Cart</span>
              <span id="cartCount" class="cart-count">0</span>
            </button>
          </a>
        </div>
        <nav class="top-tabs" aria-label="Menu Categories">
          <button class="tab-btn active" data-category="all" data-i18n="catAll"  type="button">All</button>
          <button class="tab-btn" data-category="milk-tea" data-i18n="catMilkTea" type="button">Milk Tea</button>
          <button class="tab-btn" data-category="fruit-tea" data-i18n="catFruitTea" type="button">Fruit Tea</button>
          <button class="tab-btn" data-category="slush" data-i18n="catSlushies" type="button">Slushies</button>
          <button class="tab-btn" data-category="dessert" data-i18n="catDessert" type="button">Dessert</button>
          <button class="tab-btn" data-category="hot-drinks" data-i18n="catHotDrinks" type="button">Hot Drinks</button>
          <button class="tab-btn" data-category="seasonal" data-i18n="catSeasonal" type="button">Seasonal</button>
        </nav>
      </header>

      <section class="menu-section" id="allSection">
        <!-- <h2 id="sectionTitle" data-i18n="sectionTitle">All</h2> -->

        <div class="card-row" id="menuCardRow"></div>

        <p id="noResultMessage" class="no-result" style="display: none;" data-i18n="noItemFound">No item found.</p>
      </section>
    </main>

    <div class="popup-overlay" id="popupOverlay"></div>

    <div class="addon-popup" id="addonPopup">
      <h2 id="popupDrinkName" data-i18n="customizeDrink">Customize Drink</h2>

      <form id="addonForm">
        <div class="choice-section">
          <div class="choice-header">
            <h3>Size</h3>
            <span>Required</span>
          </div>

          <div class="choice-row">
            <button type="button" class="choice-btn size-choice" data-size="Small" data-price-adjust="-0.75">Small -$0.75</button>
            <button type="button" class="choice-btn size-choice active" data-size="Medium" data-price-adjust="0">Medium</button>
            <button type="button" class="choice-btn size-choice" data-size="Large" data-price-adjust="0.75">Large +$0.75</button>
          </div>

          <input type="hidden" id="drinkSize" value="Medium">
          <input type="hidden" id="sizePriceAdjust" value="0">
        </div>

        <div class="choice-section">
          <div class="choice-header">
            <h3>Ice Level</h3>
            <span>Required</span>
          </div>

          <div class="choice-row">
            <button type="button" class="choice-btn ice-choice" data-value="0">0%</button>
            <button type="button" class="choice-btn ice-choice" data-value="25">25%</button>
            <button type="button" class="choice-btn ice-choice" data-value="50">50%</button>
            <button type="button" class="choice-btn ice-choice" data-value="75">75%</button>
            <button type="button" class="choice-btn ice-choice active" data-value="100">100%</button>
            <button type="button" class="choice-btn ice-choice" data-value="125">125%</button>
          </div>

          <input type="hidden" id="iceLevel" value="100">
        </div>

        <div class="choice-section">
          <div class="choice-header">
            <h3>Sugar Level</h3>
            <span>Required</span>
          </div>

          <div class="choice-row">
            <button type="button" class="choice-btn sugar-choice" data-value="0">0%</button>
            <button type="button" class="choice-btn sugar-choice" data-value="25">25%</button>
            <button type="button" class="choice-btn sugar-choice" data-value="50">50%</button>
            <button type="button" class="choice-btn sugar-choice" data-value="75">75%</button>
            <button type="button" class="choice-btn sugar-choice active" data-value="100">100%</button>
            <button type="button" class="choice-btn sugar-choice" data-value="125">125%</button>
          </div>

          <input type="hidden" id="sugarLevel" value="100">
        </div>

        <div class="choice-section">
          <div class="choice-header">
            <h3>Drink Quantity</h3>
          </div>

          <div class="drink-qty-row">
            <button type="button" class="round-qty-btn" id="minusDrinkQty">-</button>
            <span id="drinkQtyDisplay">1</span>
            <button type="button" class="round-qty-btn" id="plusDrinkQty">+</button>
          </div>

          <input type="hidden" id="drinkQty" value="1">
        </div>

        <div class="choice-section">
          <div class="choice-header">
            <h3>Add Toppings</h3>
          </div>

          <div id="addonOptionsContainer"></div>
        </div>

        <div class="popup-actions">
          <button type="button" class="popup-button cancel-button" id="cancelPopupBtn">Cancel</button>
          <button type="submit" class="popup-button done-button">Add To Cart</button>
        </div>
      </form>
    </div>


    <div class = "chat-window" id="chatWindow">
      <form action="#" class="form-container">
        <div class="chat-window-head">
          <h4><i class="fa fa-comment"></i> Talk to Tapi</h4>
          <span class="close-btn" onclick="closeChatWindow()">  
            <i class="fa fa-times"></i>          
          </span>
        </div>

        <div class="msg-container" id="msgContainer">
          <div class="msg">
            <p>How can I help?</p>
          </div>
        </div>

        <div class="chat-box-container">
          <div class="chat-box">
            <input type="text" placeholder="Type your message.." name="msg" required id="chatQuestion">
            <button type="button" class="send-btn" onclick="askAI()"><i class="fa fa-chevron-circle-right"></i></button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/addonpopup.js"></script>
  <script src="/js/menu.js"></script>
  <script src="/js/translate.js"></script>
  <script src="/js/chat.js"></script>
  <script src="/js/screenreader.js"></script>
</body>
</html>
