<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Team 14 Menu</title>
  <link rel="stylesheet" href="/css/menu.css">
  <link rel="stylesheet" href="/css/addonpopup.css">
</head>
<body>
  <div class="page-shell">
    <main class="menu-container">
      <header class="menu-header">
        <h1>Team 14</h1>

        <input
          type="text"
          id="searchInput"
          class="search-bar"
          placeholder="Search drinks..."
        />

        <div class="header-actions">
        <button class="rewards-btn" type="button">Rewards</button>

        <a href="/checkout" class="cart-link">
          <button class="cart-btn" id="cartBtn" type="button">
            View Cart
            <span id="cartCount" class="cart-count">0</span>
          </button>
        </a>
      </div>

        <nav class="top-tabs" aria-label="Menu Categories">
          <button class="tab-btn active" data-category="all" type="button">All</button>
          <button class="tab-btn" data-category="popular" type="button">Most Popular</button>
          <button class="tab-btn" data-category="seasonal" type="button">Seasonal</button>
        </nav>
      </header>

      <section class="menu-section" id="allSection">
        <h2 id="sectionTitle">All</h2>

        <div class="card-row" id="menuCardRow"></div>

        <p id="noResultMessage" class="no-result" style="display: none;">No item found.</p>
      </section>
    </main>

    <div class="popup-overlay" id="popupOverlay"></div>

    <div class="addon-popup" id="addonPopup">
      <h2 id="popupDrinkName">Customize Drink</h2>

      <form id="addonForm">
        <label class="addon-option">
          <input type="checkbox" name="addon" value="Boba">
          Boba
        </label>

        <label class="addon-option">
          <input type="checkbox" name="addon" value="Jelly">
          Jelly
        </label>

        <label class="addon-option">
          <input type="checkbox" name="addon" value="Oat Milk">
          Oat Milk
        </label>

        <div class="popup-actions">
          <button type="button" class="popup-button cancel-button" id="cancelPopupBtn">Cancel</button>
          <button type="submit" class="popup-button done-button">Done</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/addonpopup.js"></script>
  <script src="/js/menu.js"></script>
</body>
</html>