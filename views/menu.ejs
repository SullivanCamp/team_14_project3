<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Team 14 Menu</title>
  <link rel="stylesheet" href="/css/menu.css">
  <link rel="stylesheet" href="/css/addonpopup.css">
  <link rel="stylesheet" href="/css/chat.css">
  
</head>
<body>
  <div class="page-shell">
    <main class="menu-container">
      <header class="menu-header">
        <h1>Team 14</h1>

        <input
          type="text"
          id="searchInput"
          class="search-bar"
          placeholder="Search drinks..."
        />

        <div class="header-actions">

          <button class="chat-btn" id="chatBtn" onclick="openChatWindow()">Ask Tapi!</button>

          <div class="customer-menu-wrapper" id="customerMenuWrapper">

            <button class="customer-chip" id="customerChip" type="button">
              <span id="customerChipName">Guest</span>
              <span class="customer-chip-arrow">▾</span>
            </button>

            <div class="customer-dropdown" id="customerDropdown">
              <p class="customer-dropdown-title">Signed in as</p>
              <p class="customer-dropdown-name" id="customerDropdownName">Guest</p>
              <button class="customer-dropdown-btn" id="switchAccountBtn" type="button">Change Account</button>
              <button class="customer-dropdown-btn logout" id="logoutBtn" type="button">Log Out</button>
            </div>
          </div>

          <button class="rewards-btn" type="button" id="rewardsBtn">
            Rewards: <span id="rewardsPoints">0</span> pts
            (<span id="rewardsTier">Standard</span>)
          </button>

          <a href="/checkout" class="cart-link">
            <button class="cart-btn" id="cartBtn" type="button">
              View Cart
              <span id="cartCount" class="cart-count">0</span>
            </button>
          </a>
        </div>

        <nav class="top-tabs" aria-label="Menu Categories">
          <button class="tab-btn active" data-category="all" type="button">All</button>
          <button class="tab-btn" data-category="popular" type="button">Most Popular</button>
          <button class="tab-btn" data-category="seasonal" type="button">Seasonal</button>
        </nav>
      </header>

      <section class="menu-section" id="allSection">
        <h2 id="sectionTitle">All</h2>

        <div class="card-row" id="menuCardRow"></div>

        <p id="noResultMessage" class="no-result" style="display: none;">No item found.</p>
      </section>
    </main>

    <div class="popup-overlay" id="popupOverlay"></div>

    <div class="addon-popup" id="addonPopup">
      <h2 id="popupDrinkName">Customize Drink</h2>

      <form id="addonForm">
        <div class="custom-section">
          <div class="custom-row">
            <div class="custom-field">
              <label>Sugar Level</label>
              <select id="sugarLevel">
                <option value="0">0%</option>
                <option value="25">25%</option>
                <option value="50">50%</option>
                <option value="75">75%</option>
                <option value="100" selected>100%</option>
              </select>
            </div>

            <div class="custom-field">
              <label>Ice Level</label>
              <select id="iceLevel">
                <option value="0">0% Ice</option>
                <option value="25">25% Ice</option>
                <option value="50">50% Ice</option>
                <option value="75">75% Ice</option>
                <option value="100" selected>100% Ice</option>
              </select>
            </div>
          </div>
        </div>

        <div id="addonOptionsContainer" class="addon-grid"></div>

        <div class="popup-actions">
          <button type="button" class="popup-button cancel-button" id="cancelPopupBtn">Cancel</button>
          <button type="submit" class="popup-button done-button">Done</button>
        </div>
      </form>
    </div>


    <div class = "chat-window" id="chatWindow">
      <form action="#" class="form-container">
        <div class="chat-window-head">
          <h4><i class="fa fa-comment"></i> Talk to Tapi</h4>
          <span class="close-btn" onclick="closeChatWindow()">  
            <i class="fa fa-times"></i>          
          </span>
        </div>

        <div class="msg-container" id="msgContainer">
          <div class="msg">
            <p>How can I help?</p>
          </div>
        </div>

        <div class="chat-box-container">
          <div class="chat-box">
            <input type="text" placeholder="Type your message.." name="msg" requred id="chatQuestion">
            <button type="button" class="send-btn" onclick="askAI()"><i class="fa fa-chevron-circle-right"></i></button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/addonpopup.js"></script>
  <script src="/js/menu.js"></script>
  <script src="/js/chat.js"></script>
</body>
</html>