<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Team 14 Cashier POS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/cashier.css">
</head>
<body>
  <div class="cashier-shell">
    <header class="cashier-topbar">
      <div class="topbar-left">
        <div class="brand-block">
          <h1>Team 14 POS</h1>
          <p>Cashier Interface</p>
        </div>

        <div class="status-pill">Station A1</div>
        <div class="status-pill" id="cashierNameDisplay">Cashier: Lam</div>
      </div>

      <div class="topbar-right">
        <input
          type="text"
          id="cashierSearch"
          class="cashier-search"
          placeholder="Search drinks..."
        />
        <div class="clock-box" id="clockBox">--:--:--</div>
      </div>
    </header>

    <main class="cashier-layout">
      <aside class="order-panel">
        <div class="panel-header">
          <h2>Current Order</h2>
          <span class="order-badge" id="orderCountBadge">0 items</span>
        </div>

        <div class="order-meta">
          <div class="meta-row">
            <span>Order Type</span>
            <select id="orderTypeSelect" class="meta-select">
              <option value="Counter">Counter</option>
              <option value="Takeout">Takeout</option>
            </select>
          </div>

          <div class="meta-row">
            <span>Payment</span>
            <select id="paymentMethodSelect" class="meta-select">
              <option value="Cash">Cash</option>
              <option value="Card">Card</option>
            </select>
          </div>
        </div>

        <div class="customer-rewards-box">
          <div class="meta-row">
            <span>Customer Phone</span>
            <input
              type="text"
              id="customerPhoneInput"
              class="meta-select"
              placeholder="Enter phone number"
            />
          </div>

          <div class="order-actions" style="margin-top: 10px;">
            <button id="findCustomerBtn" class="secondary-btn" type="button">Find Customer</button>
            <button id="clearCustomerBtn" class="secondary-btn" type="button">Clear Customer</button>
          </div>

          <div style="margin-top: 12px;">
            <p><strong>Name:</strong> <span id="cashierCustomerName">Guest</span></p>
            <p><strong>Points:</strong> <span id="cashierCustomerPoints">0</span></p>
            <p><strong>Tier:</strong> <span id="cashierCustomerTier">Standard</span></p>
          </div>
          
          <div class="order-actions" style="margin-top: 10px;">
            <button id="useFreeDrinkRewardBtn" class="primary-btn" type="button" disabled>
              Use 100 pts Free Drink + 1 Topping
            </button>
          </div>

          <p id="activeRewardText" style="margin-top: 8px; font-size: 0.9rem; color: #2353b0;">
            No reward applied.
          </p>

        <div class="order-items" id="orderItems">
          <div class="empty-order" id="emptyOrderMessage">
            No items yet. Tap a drink to start the order.
          </div>
        </div>

        <div class="summary-box">
          <div class="summary-row">
            <span>Subtotal</span>
            <span id="subtotalValue">$0.00</span>
          </div>
          <div class="summary-row">
            <span>Tax</span>
            <span id="taxValue">$0.00</span>
          </div>
          <div class="summary-row total-row">
            <span>Total</span>
            <span id="totalValue">$0.00</span>
          </div>
        </div>

        <div class="order-actions">
          <button id="clearOrderBtn" class="secondary-btn" type="button">Clear Order</button>
          <button id="payNowBtn" class="primary-btn" type="button">Pay Now</button>
        </div>
      </aside>

      <section class="menu-panel">
        <div class="menu-panel-header">
          <div>
            <h2>Menu</h2>
            <p>Touch a drink to customize and add it fast.</p>
          </div>
        </div>

        <nav class="cashier-tabs" aria-label="Cashier menu categories">
          <button class="cashier-tab active" type="button" data-category="all">All</button>
          <button class="cashier-tab" type="button" data-category="popular">Popular</button>
          <button class="cashier-tab" type="button" data-category="seasonal">Seasonal</button>
        </nav>

        <div class="menu-grid" id="cashierMenuGrid"></div>

        <p class="cashier-no-result" id="cashierNoResult" style="display: none;">
          No drink found.
        </p>
      </section>
    </main>
  </div>

  <div class="modal-overlay" id="cashierModalOverlay"></div>

  <div class="cashier-modal" id="cashierModal">
    <div class="modal-header">
      <div>
        <h3 id="modalDrinkName">Customize Drink</h3>
        <p id="modalDrinkPrice">$0.00</p>
      </div>
      <button class="close-modal-btn" id="closeCashierModalBtn" type="button">×</button>
    </div>

    <div class="modal-section">
      <label class="field-label" for="drinkQtyInput">Quantity</label>
      <input id="drinkQtyInput" class="qty-input" type="number" min="1" value="1" />
    </div>

    <div class="modal-grid">
      <div class="modal-section">
        <label class="field-label" for="sugarSelect">Sugar</label>
        <select id="sugarSelect" class="custom-select">
          <option value="0">0%</option>
          <option value="25">25%</option>
          <option value="50">50%</option>
          <option value="75">75%</option>
          <option value="100" selected>100%</option>
        </select>
      </div>

      <div class="modal-section">
        <label class="field-label" for="iceSelect">Ice</label>
        <select id="iceSelect" class="custom-select">
          <option value="0">0%</option>
          <option value="25">25%</option>
          <option value="50">50%</option>
          <option value="75">75%</option>
          <option value="100" selected>100%</option>
        </select>
      </div>
    </div>

    <div class="modal-section">
      <label class="field-label">Toppings</label>
      <div class="toppings-grid" id="cashierToppingsGrid"></div>
    </div>

    <div class="modal-actions">
      <button id="cancelCashierModalBtn" class="secondary-btn" type="button">Cancel</button>
      <button id="addDrinkBtn" class="primary-btn" type="button">Add to Order</button>
    </div>
  </div>

  <script src="/js/cashier.js"></script>
</body>
</html>