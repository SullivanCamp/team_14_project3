<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>X Report</title>
  <link rel="stylesheet" href="/css/reports.css" />
</head>
<body>
  <div class="report-page">
    <header class="report-header">
      <div>
        <p class="eyebrow">Manager Reports</p>
        <h1>X Report</h1>
        <p class="subtext">Hourly sales and void activity for a selected day.</p>
      </div>
      <a class="secondary-btn" href="/reportshome">Back</a>
    </header>

    <section class="report-card filters">
      <label>
        Date
        <input type="date" id="x-date" />
      </label>
      <button id="x-load-btn" class="primary-btn">Load Report</button>
    </section>

    <section class="stats-grid">
      <article class="stat-card">
        <span class="stat-label">Total Sales</span>
        <strong id="x-total-sales">$0.00</strong>
      </article>
      <article class="stat-card">
        <span class="stat-label">Voids</span>
        <strong id="x-total-voids">0</strong>
      </article>
      <article class="stat-card">
        <span class="stat-label">Returns</span>
        <strong id="x-total-returns">$0.00</strong>
      </article>
      <article class="stat-card">
        <span class="stat-label">Discards</span>
        <strong id="x-total-discards">0</strong>
      </article>
    </section>

    <section class="report-card">
      <div class="card-title-row">
        <h2>Hourly Breakdown</h2>
        <span id="x-report-date" class="pill"></span>
      </div>

      <div class="table-wrap">
        <table class="report-table">
          <thead>
            <tr>
              <th>Hour</th>
              <th>Sales</th>
              <th>Voids</th>
              <th>Returns</th>
              <th>Discards</th>
            </tr>
          </thead>
          <tbody id="x-report-body">
            <tr>
              <td colspan="5" class="empty-cell">Loading...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script src="/js/x-report.js"></script>
</body>
</html>